## 🐍 Python Implementation

```python
class Solution:
    def minimumTotalDistance(self, robot, factory):
        robot.sort()
        factory.sort(key=lambda x: x[0])

        factory_positions = []
        for pos, cap in factory:
            factory_positions.extend([pos] * cap)

        n = len(robot)
        m = len(factory_positions)

        next_row = [0] * (m + 1)
        current = [0] * (m + 1)

        INF = 10**12

        for i in range(n - 1, -1, -1):
            if i != n - 1:
                next_row[m] = INF
            current[m] = INF

            for j in range(m - 1, -1, -1):
                assign = abs(robot[i] - factory_positions[j]) + next_row[j + 1]
                skip = current[j + 1]
                current[j] = min(assign, skip)

            next_row = current[:]

        return current[0]
```

